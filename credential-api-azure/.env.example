NODE_ENV=development
PORT=3000

# Campus Digital API key expected in the `apikey` header.
API_KEY=replace-with-a-strong-shared-api-key

# This example validates Azure Entra ID tokens.
TOKEN_IDP=azure

# Azure Entra ID validation
AZURE_TENANT_ID=your-tenant-id-or-common
AZURE_CLIENT_ID=your-azure-application-client-id
AZURE_ALLOWED_ISSUER=
