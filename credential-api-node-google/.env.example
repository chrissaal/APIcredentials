NODE_ENV=development
PORT=3000

# Campus Digital API key expected in the `apikey` header.
API_KEY=replace-with-a-strong-shared-api-key

# This example validates Google IDP tokens.
TOKEN_IDP=google

# Google IDP validation
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_ALLOWED_HOSTED_DOMAIN=
